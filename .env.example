# Add the API key(s) for whichever provider(s) you want to use.
# You only need to set the one(s) you plan to use.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
XAI_API_KEY=xai-...

# Ollama (local models) — no API key needed.
# Just install Ollama, pull a model, and select "Ollama (Local)" in the GUI.
#   ollama pull qwen3.5:27b
